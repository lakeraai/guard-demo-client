# LiteLLM UI login (for http://localhost:4000/ui)
UI_USERNAME=admin
UI_PASSWORD=demo

# Lakera Guard (optional) – for content moderation via LiteLLM proxy
# LAKERA_API_KEY=your-lakera-api-key
# LAKERA_API_BASE=https://api.lakera.ai  # optional, defaults to this

# Optional: override master key for API (default in config is sk-demo-master-key)
# LITELLM_MASTER_KEY=sk-demo-master-key
