# Azure model backend key used by LiteLLM routes in litellm/config.yaml
AZURE_API_KEY=your-azure-api-key

# Lakera Guard (optional) for content moderation / guardrails
# LAKERA_API_KEY=your-lakera-api-key
# LAKERA_PROJECT_ID=project-xxxxxxxxxx
# LAKERA_API_BASE=https://api.lakera.ai

# LiteLLM proxy + DB runtime
LITELLM_PROXY_USE_DATABASE=1
DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm

# LiteLLM UI login (for http://localhost:4000/ui)
UI_USERNAME=admin
UI_PASSWORD=demo
DISABLE_ADMIN_UI=False

# Dockerized LiteLLM proxy settings
LITELLM_DOCKER_IMAGE=litellm/litellm:v1.82.3
LITELLM_DOCKER_PLATFORM=linux/amd64

# Optional: override proxy master key (default in config is sk-demo-master-key)
# LITELLM_MASTER_KEY=sk-demo-master-key
